    "Clear all browsing data including history, favorites, and open tabs?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مسح جميع بيانات التصفح بما في ذلك السجل والمفضلة وعلامات التبويب المفتوحة؟"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Esborrar totes les dades de navegació incloent historial, preferits i pestanyes obertes?"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smazat všechna data prohlížení včetně historie, oblíbených a otevřených karet?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ryd alle browserdata inklusive historik, favoritter og åbne faner?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Browserdaten einschließlich Verlauf, Favoriten und offene Tabs löschen?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαγραφή όλων των δεδομένων περιήγησης, συμπεριλαμβανομένου του ιστορικού, των αγαπημένων και των ανοιχτών καρτελών;"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Borrar todos los datos de navegación, incluyendo historial, favoritos y pestañas abiertas?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyhjennä kaikki selaustiedot mukaan lukien historia, suosikit ja avoimet välilehdet?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacer toutes les données de navigation, y compris l'historique, les favoris et les onglets ouverts ?"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrisati sve podatke pregledavanja uključujući povijest, favorite i otvorene kartice?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Törli az összes böngészési adatot, beleértve az előzményeket, a kedvenceket és a nyitott lapokat?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus semua data penjelajahan termasuk riwayat, favorit, dan tab yang terbuka?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancellare tutti i dati di navigazione, inclusa la cronologia, i preferiti e le schede aperte?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴、お気に入り、開いているタブを含むすべての閲覧データを消去しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방문 기록, 즐겨찾기, 열린 탭을 포함한 모든 인터넷 사용 기록을 삭제하시겠습니까?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Slette alle nettleserdata inkludert historikk, favoritter og åpne faner?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle browsegegevens wissen inclusief geschiedenis, favorieten en open tabbladen?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyczyścić wszystkie dane przeglądania, w tym historię, ulubione i otwarte karty?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar todos os dados de navegação, incluindo histórico, favoritos e abas abertas?"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ștergi toate datele de navigare, inclusiv istoricul, favoritele și filele deschise?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить все данные просмотра, включая историю, избранное и открытые вкладки?"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vymazať všetky údaje prehliadania vrátane histórie, obľúbených a otvorených kariet?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rensa alla webbläsardata inklusive historik, favoriter och öppna flikar?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ล้างข้อมูลการเรียกดูทั้งหมด รวมถึงประวัติ รายการโปรด และแท็บที่เปิดอยู่?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçmiş, sık kullanılanlar ve açık sekmeler dahil tüm tarama verileri temizlensin mi?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видалити всі дані перегляду, включаючи історію, обране та відкриті вкладки?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa tất cả dữ liệu duyệt web bao gồm lịch sử, mục yêu thích và các tab đang mở?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除所有浏览数据，包括历史记录、收藏夹和打开的标签页？"
          }
        }
      }
    },
