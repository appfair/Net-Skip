    "Sites listed here bypass content blocking. Use bare domains like example.com or wildcards like *.example.com." : {
      "comment" : "description for whitelisted sites editor",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "تتجاوز المواقع المدرجة هنا حظر المحتوى. استخدم نطاقات مجردة مثل example.com أو أحرف بدل مثل ‎*.example.com‎."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die hier aufgeführten Websites umgehen den Inhaltsblocker. Verwende reine Domains wie example.com oder Platzhalter wie *.example.com."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Los sitios listados aquí omiten el bloqueo de contenido. Usa dominios simples como example.com o comodines como *.example.com."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Les sites listés ici contournent le blocage de contenu. Utilisez des domaines bruts comme example.com ou des caractères génériques comme *.example.com."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "यहाँ सूचीबद्ध साइटें सामग्री ब्लॉकिंग को बायपास करती हैं। example.com जैसे सादे डोमेन या *.example.com जैसे वाइल्डकार्ड का उपयोग करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Situs yang tercantum di sini melewati pemblokiran konten. Gunakan domain polos seperti example.com atau wildcard seperti *.example.com."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "I siti elencati qui aggirano il blocco contenuti. Usa domini puri come example.com o caratteri jolly come *.example.com."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ここに記載されたサイトはコンテンツブロックを回避します。example.com のようなドメイン名や *.example.com のようなワイルドカードを使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "여기에 나열된 사이트는 콘텐츠 차단을 우회합니다. example.com 같은 도메인 또는 *.example.com 같은 와일드카드를 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Os sites listados aqui ignoram o bloqueio de conteúdo. Use domínios simples como example.com ou curingas como *.example.com."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Сайты из этого списка обходят блокировку контента. Используйте чистые домены, например example.com, или подстановочные шаблоны, например *.example.com."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此处列出的网站将跳过内容拦截。请使用 example.com 这样的纯域名或 *.example.com 这样的通配符。"
          }
        }
      }
    },
