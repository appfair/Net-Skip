    "NSBluetoothAlwaysUsageDescription" : {
      "comment" : "Privacy - Bluetooth Always Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يستخدم Net Skip البلوتوث للسماح للمواقع التي تزورها بالتواصل مع الأجهزة القريبة مثل أجهزة تتبع اللياقة وأذرع التحكم وأجهزة إنترنت الأشياء عبر واجهة Web Bluetooth عند منحها الإذن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip verwendet Bluetooth, damit besuchte Websites mit deiner Erlaubnis über die Web-Bluetooth-API mit Geräten in der Nähe wie Fitness-Trackern, Spielecontrollern und IoT-Geräten kommunizieren können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Net Skip uses Bluetooth so that websites you visit can communicate with nearby devices such as fitness trackers, game controllers, and IoT hardware via the Web Bluetooth API when you grant them permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip usa Bluetooth para que los sitios web que visitas puedan comunicarse con dispositivos cercanos como pulseras de actividad, mandos de juego y hardware IoT a través de la API Web Bluetooth cuando les concedes permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip utilise le Bluetooth pour permettre aux sites web que vous consultez de communiquer, avec votre autorisation, avec des appareils à proximité tels que des trackers d’activité, des manettes et du matériel IoT via l’API Web Bluetooth."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip ब्लूटूथ का उपयोग करता है ताकि जिन वेबसाइटों पर आप जाते हैं वे आपकी अनुमति देने पर Web Bluetooth API के माध्यम से फ़िटनेस ट्रैकर, गेम कंट्रोलर और IoT हार्डवेयर जैसे आस-पास के उपकरणों से संवाद कर सकें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip menggunakan Bluetooth agar situs web yang Anda kunjungi dapat berkomunikasi dengan perangkat di sekitar seperti pelacak kebugaran, pengontrol gim, dan perangkat IoT melalui Web Bluetooth API saat Anda memberinya izin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip utilizza il Bluetooth affinché i siti web che visiti possano comunicare con dispositivi nelle vicinanze come fitness tracker, controller di gioco e dispositivi IoT tramite l’API Web Bluetooth quando concedi loro l’autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skipは、許可した場合に閲覧中のウェブサイトがWeb Bluetooth APIを介してフィットネストラッカー、ゲームコントローラ、IoTデバイスなど近くのデバイスと通信できるようにBluetoothを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip는 사용자가 권한을 허용하면 방문한 웹사이트가 Web Bluetooth API를 통해 피트니스 트래커, 게임 컨트롤러, IoT 기기 등 주변 기기와 통신할 수 있도록 블루투스를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O Net Skip usa Bluetooth para que os sites visitados possam se comunicar com dispositivos próximos, como monitores de atividades, controles de jogos e dispositivos IoT, pela API Web Bluetooth quando você conceder permissão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip использует Bluetooth, чтобы посещаемые сайты могли с вашего разрешения взаимодействовать с находящимися рядом устройствами — фитнес-трекерами, игровыми контроллерами и оборудованием IoT — через Web Bluetooth API."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip 使用蓝牙，以便您访问的网站在您授权后可通过 Web Bluetooth API 与健身追踪器、游戏手柄和 IoT 设备等附近设备通信。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription" : {
      "comment" : "Privacy - Calendars Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يحتاج Net Skip إلى الوصول إلى تقويمك حتى تتمكن المواقع التي تزورها من إضافة أحداث مثل الحجوزات والمواعيد ودعوات الاجتماعات عند منحها الإذن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip benötigt Zugriff auf deinen Kalender, damit besuchte Websites mit deiner Erlaubnis Termine wie Buchungen, Reservierungen und Besprechungseinladungen hinzufügen können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Net Skip needs access to your calendar so that websites you visit can add events such as bookings, reservations, and meeting invitations when you grant them permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necesita acceder a tu calendario para que los sitios web que visitas puedan añadir eventos como reservas, citas e invitaciones a reuniones cuando les concedes permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip a besoin d’accéder à votre calendrier pour permettre aux sites web que vous consultez d’ajouter, avec votre autorisation, des événements tels que des réservations, des rendez-vous et des invitations à des réunions."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip को आपके कैलेंडर तक पहुँच की आवश्यकता है ताकि जिन वेबसाइटों पर आप जाते हैं वे आपकी अनुमति देने पर बुकिंग, आरक्षण और मीटिंग आमंत्रण जैसे ईवेंट जोड़ सकें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip memerlukan akses ke kalender Anda agar situs web yang Anda kunjungi dapat menambahkan acara seperti pemesanan, reservasi, dan undangan rapat saat Anda memberinya izin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necessita dell’accesso al tuo calendario affinché i siti web che visiti possano aggiungere eventi come prenotazioni, appuntamenti e inviti a riunioni quando concedi loro l’autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skipは、許可した場合に閲覧中のウェブサイトが予約や会議の招待などの予定をカレンダーに追加できるよう、カレンダーへのアクセスを必要とします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip는 사용자가 권한을 허용하면 방문한 웹사이트가 예약, 일정, 회의 초대 등의 이벤트를 추가할 수 있도록 캘린더 접근 권한이 필요합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O Net Skip precisa acessar seu calendário para que os sites visitados possam adicionar eventos como reservas, agendamentos e convites de reuniões quando você conceder permissão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip требуется доступ к вашему календарю, чтобы посещаемые сайты могли с вашего разрешения добавлять события — бронирования, встречи и приглашения на совещания."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip 需要访问您的日历，以便您访问的网站在您授权后可添加预订、预约和会议邀请等事件。"
          }
        }
      }
    },
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يحتاج Net Skip إلى الوصول إلى الكاميرا حتى تتمكن المواقع التي تزورها من استخدامها لمكالمات الفيديو ومسح رموز QR والتقاط الصور عند منحها الإذن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip benötigt Zugriff auf deine Kamera, damit besuchte Websites sie mit deiner Erlaubnis für Videoanrufe, das Scannen von QR-Codes und das Aufnehmen von Fotos verwenden können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Net Skip needs access to your camera so that websites you visit can use it for video calls, scanning QR codes, and capturing photos when you grant them permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necesita acceder a tu cámara para que los sitios web que visitas puedan usarla para videollamadas, escanear códigos QR y hacer fotos cuando les concedes permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip a besoin d’accéder à votre caméra afin que les sites web que vous consultez puissent l’utiliser, avec votre autorisation, pour les appels vidéo, la lecture de codes QR et la prise de photos."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip को आपके कैमरे तक पहुँच की आवश्यकता है ताकि जिन वेबसाइटों पर आप जाते हैं वे आपकी अनुमति देने पर वीडियो कॉल, QR कोड स्कैन और फ़ोटो खींचने के लिए इसका उपयोग कर सकें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip memerlukan akses ke kamera Anda agar situs web yang Anda kunjungi dapat menggunakannya untuk panggilan video, memindai kode QR, dan mengambil foto saat Anda memberinya izin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necessita dell’accesso alla tua fotocamera affinché i siti web che visiti possano usarla per videochiamate, scansione di codici QR e scatto di foto quando concedi loro l’autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skipは、許可した場合に閲覧中のウェブサイトがビデオ通話、QRコードのスキャン、写真撮影に利用できるよう、カメラへのアクセスを必要とします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip는 사용자가 권한을 허용하면 방문한 웹사이트가 영상 통화, QR 코드 스캔, 사진 촬영에 사용할 수 있도록 카메라 접근 권한이 필요합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O Net Skip precisa acessar sua câmera para que os sites visitados possam usá-la em chamadas de vídeo, leitura de códigos QR e captura de fotos quando você conceder permissão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip требуется доступ к камере, чтобы посещаемые сайты могли с вашего разрешения использовать её для видеозвонков, сканирования QR-кодов и съёмки фотографий."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip 需要访问您的相机，以便您访问的网站在您授权后可用于视频通话、扫描二维码和拍摄照片。"
          }
        }
      }
    },
    "NSContactsUsageDescription" : {
      "comment" : "Privacy - Contacts Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يحتاج Net Skip إلى الوصول إلى جهات اتصالك حتى تتمكن من ملء الأسماء وعناوين البريد الإلكتروني وأرقام الهواتف تلقائياً في نماذج الويب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip benötigt Zugriff auf deine Kontakte, damit du Namen, E-Mail-Adressen und Telefonnummern schnell automatisch in Webformulare eintragen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Net Skip needs access to your contacts so that you can quickly autofill names, email addresses, and phone numbers into web forms."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necesita acceder a tus contactos para que puedas autocompletar rápidamente nombres, direcciones de correo y números de teléfono en formularios web."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip a besoin d’accéder à vos contacts pour vous permettre de remplir rapidement et automatiquement noms, adresses e-mail et numéros de téléphone dans les formulaires web."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip को आपके संपर्कों तक पहुँच की आवश्यकता है ताकि आप वेब फ़ॉर्म में नाम, ईमेल पते और फ़ोन नंबर शीघ्रता से ऑटोफ़िल कर सकें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip memerlukan akses ke kontak Anda agar Anda dapat mengisi nama, alamat email, dan nomor telepon di formulir web secara otomatis dengan cepat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip necessita dell’accesso ai tuoi contatti per consentirti di compilare automaticamente nomi, indirizzi e-mail e numeri di telefono nei moduli web."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
