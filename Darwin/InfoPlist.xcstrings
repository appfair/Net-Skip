    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يستخدم Net Skip موقعك لتوفير ميزات تعتمد على الموقع للمواقع التي تزورها، بما في ذلك التحديثات المستمرة لصفحات الملاحة والخرائط عند منحها الإذن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip verwendet deinen Standort, um besuchten Websites standortbezogene Funktionen bereitzustellen, einschließlich fortlaufender Aktualisierungen für Navigations- und Kartenseiten, sofern du dies erlaubst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Net Skip uses your location to provide location-aware features to websites you visit, including continuous updates for navigation and mapping pages when you grant them permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip usa tu ubicación para ofrecer funciones basadas en la ubicación a los sitios web que visitas, incluidas actualizaciones continuas para páginas de navegación y mapas cuando les concedes permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip utilise votre position pour fournir des fonctionnalités géolocalisées aux sites web que vous consultez, y compris des mises à jour continues pour les pages de navigation et de cartographie, lorsque vous leur en accordez l’autorisation."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip आपके स्थान का उपयोग उन वेबसाइटों को स्थान-आधारित सुविधाएँ प्रदान करने के लिए करता है जिन पर आप जाते हैं, जिसमें आपकी अनुमति देने पर नेविगेशन और मानचित्र पृष्ठों के लिए निरंतर अपडेट शामिल हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip menggunakan lokasi Anda untuk menyediakan fitur berbasis lokasi pada situs web yang Anda kunjungi, termasuk pembaruan berkelanjutan untuk halaman navigasi dan peta saat Anda memberinya izin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skip utilizza la tua posizione per fornire funzionalità basate sulla posizione ai siti web che visiti, inclusi aggiornamenti continui per le pagine di navigazione e mappe quando concedi loro l’autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Net Skipは、許可した場合に閲覧中のウェブサイトに位置情報機能を提供し、ナビゲーションや地図のページで継続的な位置情報の更新を行うため、位置情報を使用します。"
